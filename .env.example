# --- SERVER CONFIGURATION ---
NODE_ENV=production
PORT=5000
# IMPORTANT: Provide the full connection string from MongoDB Atlas
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/dbname
# The URL of your deployed Vercel frontend (e.g. https://my-app.vercel.app)
FRONTEND_URL=

# --- AUTHENTICATION ---
# Generate long random strings for secrets
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# --- EXTERNAL SERVICES ---
# AI Provider (Using Gemini via OpenAI-compatible API)
AI_PROVIDER=gemini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Cloudinary (Sign up at cloudinary.com)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google OAuth (Create at Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
